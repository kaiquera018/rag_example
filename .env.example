#openrouter configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_SITE=https://localhost:3000
OPENROUTER_SITE_NAME=RAG Example


#models
NLP_MODEL='gpt-3.5-turbo'

#Embeddings using transformers.js locally
EMBEDDINGS_MODEL='Xenova/all-MiniLM-L6-v2'

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_URI=bolt://localhost:7687
NEO4J_DATABASE=neo4j

# Vector search threshold
NEO4J_VECTOR_THRESHOLD=0.9